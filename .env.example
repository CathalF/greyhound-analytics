# Copy this file to .env and fill in your values.
# DATABASE_URL is required. All other variables have defaults in config.yaml.

# -------------------------------------------------------------------
# Required
# -------------------------------------------------------------------

# PostgreSQL connection string
# Local:   postgresql://myuser:mypassword@localhost:5432/greyhound
# Neon:    postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/greyhound
# Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -------------------------------------------------------------------
# Optional — Flask
# -------------------------------------------------------------------

# Secret key used for Flask session signing. Change this in production.
SECRET_KEY=change-me-in-production

# Set to false in production
FLASK_DEBUG=true

# -------------------------------------------------------------------
# Optional — Email alerts (only needed if alerts.email.enabled: true in config.yaml)
# -------------------------------------------------------------------

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=alerts@greyhound-analytics.local
